# ─── Dependencies ───────────────────────────────────────────
node_modules/

# ─── App data & media content ───────────────────────────────
# Actual library content (photos / videos / comics / thumbnails) — never commit
programm/data/
programm/thumbs/
programm/cache/

# ─── Metadata & backups ─────────────────────────────────────
programm/metadata.json
programm/metadata.json.bak*
programm/*.bak
programm/*.bak-*
**/*.json.bak*

# ─── Electron runtime data ──────────────────────────────────
programm/electron-user-data/
**/electron-user-data/
out/
dist/

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment & secrets ──────────────────────────────────
.env
.env.*
!.env.example

# ─── OS files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
